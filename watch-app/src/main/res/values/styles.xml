<resources>

    <style name="MainActivityTheme.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@android:style/Theme.DeviceDefault</item>
    </style>

    <!-- 전화 수신 화면처럼 앱 로고 스플래시 없이 알람 내용이 바로 보이도록,
         시스템이 자동으로 그리는 starting window(구버전) / 스플래시 스크린(12+)을 끈다. -->
    <style name="StockAlarmActivityTheme" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowDisablePreview">true</item>
    </style>
</resources>