<full-backup-content>
    <!--
   Tink이 Android Keystore 마스터키로 감싼 토큰 암호화 키셋을 저장하는 파일.
   Keystore 키는 앱 삭제 시 함께 삭제되어 백업 복원 대상이 될 수 없으므로,
   이 파일이 복원되면 재설치 후 존재하지 않는 키 ID를 참조하게 되어
   InvalidKeyException으로 앱이 크래시한다. 백업 대상에서 제외해
   재설치 시 새 키셋이 새로 생성되도록 한다.
    -->
    <exclude domain="sharedpref" path="toss_watch_keyset_prefs.xml"/>
</full-backup-content>